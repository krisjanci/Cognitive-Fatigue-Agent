{
  "manifest_version": 3,
  "name": "Fatigue MVP (Chapter 4 Data Version)",
  "version": "3.0",
  "permissions": ["storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "bg.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}